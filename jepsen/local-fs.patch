+(defn fsync-everything
+  "ZeroFS's fsync is a global db.flush() barrier: it makes every pending write
+  durable (data and metadata alike), not just the fsync'd inode. Moves the whole
+  cache, every entry and every inode, to disk."
+  [fs]
+  (let [fs (reduce fsync-path* fs (keys (get-in fs [:cache :entries])))]
+    (reduce fsync-inode fs (keys (get-in fs [:cache :inodes])))))
