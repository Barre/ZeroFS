+(defn fsync-everything
+  "ZeroFS's fsync is a global db.flush() barrier: it makes every pending write
+  durable (data and metadata alike), not just the fsync'd inode. Moves the whole
+  cache, every entry and every inode, to disk."
+  [fs]
+  (let [fs (reduce fsync-path* fs (keys (get-in fs [:cache :entries])))]
+    (reduce fsync-inode fs (keys (get-in fs [:cache :inodes])))))
+
 (defn inodes-in-disk-entries
   "Returns a collection (including duplicates) of every inode referenced on
   disk in a filesystem."
@@ -419,7 +427,10 @@
     (persistent!
       (reduce (fn [paths [path cache-entry]]
                 (if (tombstone? cache-entry)
-                  (dissoc! paths path)
+                  ; disk-paths is a set, so remove with disj! (dissoc! is for
+                  ; maps). This path is only reached once the cache can hold a
+                  ; tombstone, i.e. once metadata isn't written through.
+                  (disj! paths path)
                   (conj! paths path)))
               (transient disk-paths)
               (-> fs :cache :entries (children path))))))
@@ -634,11 +645,9 @@
 
       :fsync
