 (defn fs-op-gen
   "test.check generator for fs test ops. Generates append, write, mkdir, mv,
   read, etc. Options are:
 
     :dont                     A set of fs to skip
-    :lose-unfsynced-writes    If set, emits operations to lose un-fsynced
-                              writes"
-  [{:keys [dont lose-unfsynced-writes]}]
-  (let [fs (keys funs)
+    :lose-unfsynced-writes    If set, emits operations to lose un-fsynced writes
+    :failover                 If set, emits HA leader-failover operations"
+  [{:keys [dont lose-unfsynced-writes failover]}]
+  (let [; faults are not ordinary ops: only emit each when explicitly requested,
+        ; so plain conformance runs (and backends that don't implement a fault)
+        ; never see it.
+        faults #{:lose-unfsynced-writes :failover}
+        fs (remove faults (keys funs))
         fs (remove dont fs)
-        fs (if lose-unfsynced-writes
-             (conj fs :lose-unfsynced-writes)
-             fs)
+        fs (if lose-unfsynced-writes (conj fs :lose-unfsynced-writes) fs)
+        fs (if failover (conj fs :failover) fs)
         gens (->> fs
                   (map funs)
                   (mapv (juxt :weight :gen)))]
         (g/frequency gens)))
 
 (defn fs-history-gen
-  "Generates a whole history"
-  [opts]
-  (g/scale (partial * 1000)
+  "Generates a whole history. The size multiplier sets how long histories get;
+  upstream's 1000 is good for deep conformance runs, but it makes crash runs
+  intractable (every few ops triggers a server kill and recovery), so it's
+  tunable via --history-scale."
+  [{:keys [history-scale] :as opts}]
+  (g/scale (partial * (or history-scale 1000))
     (g/vector (fs-op-gen opts))))
 
