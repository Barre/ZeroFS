+        ; ZeroFS: any fsync is a global db.flush(), so flush the whole
+        ; filesystem regardless of which path's fd was fsynced.
+        [(cond (or (link? entry) (dir? entry)) (fsync-everything fs)
 
                :else (throw+ {:type  ::can't-fsync
                               :path  value
