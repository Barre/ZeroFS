# Environment for the zerofs service. Referenced by ${VAR} from
# /etc/zerofs/config.toml and loaded by systemd before the service starts.
# This file is root-only (mode 0600) because it holds secrets.

# Encryption password for the filesystem. Required.
ZEROFS_PASSWORD=

# S3 credentials, if using the [aws] block in config.toml.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Any other ${VAR} you reference from config.toml can be defined here, e.g.
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_ACCOUNT_KEY=
# GOOGLE_SERVICE_ACCOUNT=
